#!/usr/bin/env bash
# shellcheck disable=SC1091
set -x
date
rundir="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
HOMErrfs="$(dirname "$rundir")"

module purge
source "${HOMErrfs}/workflow/tools/detect_machine.sh"
"${HOMErrfs}/workflow/tools/init.sh"

EXEC="${HOMErrfs}/sorc/MPASBlend/bin/mpas_blending"

rm -rf "${HOMErrfs}/sorc/MPASBlend/build"
rm -rf "${HOMErrfs}/sorc/MPASBlend/bin"

cd "${HOMErrfs}/sorc/MPASBlend" || exit 1
./build.sh

mkdir -p "${HOMErrfs}/exec"
echo "copy ${EXEC} to ../exec/mpas_blending.x"
cp "${EXEC}" "${HOMErrfs}/exec/mpas_blending.x"

exit 0
