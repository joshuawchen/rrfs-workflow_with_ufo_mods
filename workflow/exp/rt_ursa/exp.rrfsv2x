#!/usr/bin/env bash
# Aloha! This file is to setup some top level experiment options
#
# shellcheck disable=all
export NET=rrfs                    # rrfs, rtma, 
export MESH_NAME=conus3km         # conus12km, conus3km, atl3km, etc
export WGF="det"   # working group function = "det", "enkf", "ens", "firewx"
export EXP_NAME=RRFSv2X
export VERSION=$(cat ./VERSION)
export TAG=rrfsv2x
export OPSROOT=/scratch3/BMC/rtwrfruc/RRFSv2X/NCO_dirs/${EXP_NAME}
export EXPDIR=${OPSROOT}/exp/rrfs${WGF}
export COMROOT=${OPSROOT}/com      # task input and output data as well as logs
export DATAROOT=${OPSROOT}/stmp    # task workdirs ($DATA) which to be removed immediately upon task completion unless KEEPDATA=YES
#
#export SFC_UPDATE_SOURCE_DIR=/scratch3/BMC/rtwrfruc/RRFSv2X/NCO_dirs/MPAS_RAP
export NSST_SOURCE_DIR=/public/data/grids/ncep/sst/0p083deg/grib2
export LAKE_SOURCE_DIR=/public/data/grids/rrfs_a
#
export REALTIME=true     # true, false
export ZETA_LEVELS="L60.txt"
#
export DO_IODA=true
export DO_JEDI=true
export SNUDGETYPES="GGG" # G=gsd_update_soiltq from GSI; P=2022 J Hydro paper; chars=SoilT,SnowT,SoilQ
export COLDSTART_CYCS_DO_DA=false #true
export DO_NONVAR_CLOUD_ANA=true
export DO_CHEMISTRY=false
export DO_RADAR_REF=true  # does not work for 3DVar, only EnVar or GETKF
export RADARREFL_TIMELEVEL="00"  # 00 15 30 45 min
export SAT_USELIST=""  # check config.base on how to set up this variable
export HYB_WGT_ENS=0.5
export HYB_WGT_STATIC=0.5
export HYB_ENS_TYPE=1      # 1.rrfs; 2.interpolated GEFS/GDAS; 0.TBD on the fly (rrfs->GDAS->3DVAR)
export HYB_ENS_PATH=""     # if empty, the workflow will try to find ensembles automatically
export ENS_SIZE=30
export ENS_BEC_LOOK_BACK_HRS=1  # define the hours going back for ensemble forecast files for the ensemble BEC
export DO_HOFX=false
export HOFX_FHRS="000 001 012"
export DO_SFC_UPDATE=true # do sfc update at cold start cycs
export SFC_UPDATE_LOOK_BACK_HRS=3  # hours going back to look for surface update source files (mpasout)

export STATIC_BEC_MODEL="GSIBEC" # the static bec model, GSIBEC and BUMPBEC
export GSIBEC_X=40 #GSIBEC_X * GSIBEC_Y should match the number of MPI tasks
export GSIBEC_Y=20

export DO_CYC=true
export CYC_INTERVAL=1
for i in {0..23};    do arr[$i]="03"; done # 3hr fcst
for i in {0..23..12}; do arr[$i]="72"; done # 24hr fcst every 12hrs
export FCST_LEN_HRS_CYCLES="${arr[*]}"
export HISTORY_INTERVAL=1
export DIAG_INTERVAL=1
export MPASOUT_TIMELEVELS='0 1 2 3 15 27'
export POST_GROUP_TOT_NUM=10

export IC_OFFSET=3
export LBC_OFFSET=6
export LBC_LENGTH=84
export LBC_INTERVAL=1
export LBC_UNGRIB_GROUP_TOTAL_NUM=3
export LBC_GROUP_TOTAL_NUM=6
export PREP_LBC_LOOK_BACK_HRS=11 # define the hours going back for prep_lbc to find lbc files

export RETRO_PERIOD="2024052700-2024052800"
export LBC_CYCS="00 12"  # evenly divide 24 hours, e.g., "00 12", "00 06 12 18", etc
export COLDSTART_CYCS="03 15"   # cycles to cold start from external models
export SST_UPDATE_CYCS="00 12"

#export DO_SPINUP=true
#export PRODSWITCH_CYCS="06 18"  # cycles to PROD switch to the spun-up ICs
#
# set as follows to start spinup at 03/15z
#export DO_SPINUP=true
#export IC_OFFSET=3
#export COLDSTART_CYCS="03 15"
#export PRODSWITCH_CYCS="09 21"
#
export DO_PYDAMONITOR=true
export DO_GRAPHICS=true
export GRAPHICS_MODEL="RRFSv2X"   # Model Name in the plots
export GRAPHICS_TILES="full NE NC NW SE SC SW EastCO"
export GRAPHICS_ZIP=true
export DO_ARCHIVE=true
export ARCHIVE_INTERVAL=1  # run the archive task every several hours
export ARCHIVE_HPSSDIR="/5year/BMC/wrfruc/rrfsv2x"
export ARCHIVE_COM1_SPEC='{"include":"ioda*, jedivar, nonvar*, fcst, upp, pyDAmonitor, nclprd", "exclude":""}'  # use " inside and ' outside
export ARCHIVE_STMP=''  # eg. 'fcst,mpassit'  # archive files under the given task umbrella directories
export ARCHIVE_STMP_INTERVAL='1'  # ARCHIVE_STMP_INTERVAL must divide ARCHIVE_INTERVAL evenly
#
export WALLTIME_FCST="8:00:00"
export WALLTIME_SAVE_FCST="0:30:00"
export WALLTIME_MPASSIT="3:00:00"
export WALLTIME_UPP="3:00:00"
export WALLTIME_JEDIVAR="00:25:00"
# Ursa
export ACCOUNT="rtwrfruc"
export QUEUE="hpq"   # "windfall"
export PARTITION="u1-compute"
#
export NODES_PREP_IC="<nodes>1:ppn=10</nodes>"
export NODES_IC="<nodes>2:ppn=192</nodes>"
export NODES_LBC="<nodes>2:ppn=192</nodes>"
export NODES_FCST="<nodes>10:ppn=160</nodes>"
export NODES_MPASSIT="<nodes>1:ppn=160</nodes>"
export NODES_UPP="<nodes>1:ppn=160</nodes>"
export NODES_JEDIVAR="<nodes>20:ppn=40</nodes>"
export NODES_IODA_MRMS_REFL="<nodes>1:ppn=40</nodes>"
#
export KEEPDATA=YES
export MAXTRIES=3
export STMP_RETENTION_CYCS=26
export COM_RETENTION_CYCS='{"default": 96, "lbc,fcst": 72, "upp,nclprd,pyDAmonitor": 960}'  # use " inside and ' outside
export CYCLETHROTTLE=3600
export CYCLELIFESPAN=2
#
# local.setup: setup some local options specific to a platform or an experiment
#
# set up IC, LBC sources and A/Q/P/R information
export IC_EXTRN_MDL_NAME="GFS"
export IC_EXTRN_MDL_FILENAME_PATTERN="gfs.@Y@m@d/@H/atmos/gfs.t@Hz.pgrb2.0p25.f^HHH^"
export IC_EXTRN_MDL_FILENAME_PATTERN_B="gfs.@Y@m@d/@H/atmos/gfs.t@Hz.pgrb2b.0p25.f^HHH^"
export LBC_EXTRN_MDL_NAME=${IC_EXTRN_MDL_NAME}
export LBC_EXTRN_MDL_FILENAME_PATTERN=${IC_EXTRN_MDL_FILENAME_PATTERN}
export LBC_EXTRN_MDL_FILENAME_PATTERN_B=${IC_EXTRN_MDL_FILENAME_PATTERN_B}
export IC_EXTRN_MDL_BASEDIR="/public/data/grids/gfs/ncep"
export LBC_EXTRN_MDL_BASEDIR=${IC_EXTRN_MDL_BASEDIR}
export OBSPATH="/public/data/grids/rap/obs"
export OBSPATH_NSSLMOSIAC="/public/data/radar/mrms"

#
export STARTTIME_UNGRIB_IC="00:05:00"
export STARTTIME_UNGRIB_LBC="00:05:00"
export STARTTIME_IC="00:10:00"
export STARTTIME_LBC="00:10:00"
export STARTTIME_IODA_BUFR="00:40:00"
export STARTTIME_NONVAR_REFLOBS="00:40:00"
export STARTTIME_NONVAR_BUFROBS="00:40:00"
export STARTTIME_IODA_MRMS_REFL="00:40:00"
export STARTTIME_JEDIVAR="00:40:00"
export STARTTIME_FCST="00:10:00"
export STARTTIME_MPASSIT="00:15:00"
export STARTTIME_UPP="00:15:00"
export STARTTIME_PREP_IC="03:00:00"
export STARTTIME_PREP_LBC="00:15:00"
export MORE_XML_ENTITIES=true
export DO_CLEAN=true
export USE_THE_LATEST_SATBIAS=false
